def cmd_bridge(args: list):
    """Parse and display agent bridge conversations."""
    if not os.path.exists(BRIDGE_LOG):
        print("No bridge conversation log found.")
        return

    if "--stats" in args:
        _bridge_stats()
        return

    # Show conversations, default: today only
    show_all = "--all" in args
    n_limit = None
    for i, a in enumerate(args):
        if a.isdigit():
            n_limit = int(a)

    today = datetime.now().strftime("%Y-%m-%d")
    messages = []

    with open(BRIDGE_LOG) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            m = re.match(r'\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] (IN|OUT) \(([^)]+)\): (.+)', line)
            if m:
                ts, direction, host, msg = m.groups()
                date_part = ts[:10]
                if not show_all and date_part != today:
                    continue
                messages.append({
                    "timestamp": ts,
                    "direction": "recv" if direction == "IN" else "sent",
                    "host": host,
                    "message": msg,
                })

    if not messages:
        print(f"  No bridge messages {'today' if not show_all else 'found'}.")
        return

    if n_limit:
        messages = messages[-n_limit:]

    for msg in messages:
        arrow = "<<" if msg["direction"] == "recv" else ">>"
        label = "Ela" if msg["direction"] == "recv" else "Me"
        # Truncate long messages for display
        text = msg["message"]
        if len(text) > 120:
            text = text[:117] + "..."
        print(f"  {msg['timestamp']}  {arrow} {label}: {text}")


def _bridge_stats():
    """Show bridge message statistics."""
    if not os.path.exists(BRIDGE_LOG):
        print("No bridge log.")
        return

    sent = 0
    recv = 0
    days = set()

    with open(BRIDGE_LOG) as f:
        for line in f:
            m = re.match(r'\[(\d{4}-\d{2}-\d{2}) \d{2}:\d{2}:\d{2}\] (IN|OUT)', line)
            if m:
                days.add(m.group(1))
                if m.group(2) == "OUT":
                    sent += 1
                else:
                    recv += 1

    total = sent + recv
    num_days = len(days)
    avg = total / num_days if num_days else 0

    print(f"\n  Bridge Statistics:")
    print(f"    Total messages: {total} ({sent} sent, {recv} received)")
    print(f"    Active days: {num_days}")
    print(f"    Average: {avg:.1f} messages/day")
    if days:
        print(f"    First: {min(days)}")
        print(f"    Last:  {max(days)}")


