    path = csv_path or DEFAULT_CSV
    result = parse_and_load(path)
    print(f"Loaded {result['rows_inserted']} transactions from {os.path.basename(result['file'])}")


def main():
    init_db()
    args = sys.argv[1:]

    if not args:
        print(__doc__)
        return

    cmd = args[0]

    if cmd == "last":
        n = int(args[1]) if len(args) > 1 else 10
        cmd_last(n)
    elif cmd == "location":
        cmd_location()
    elif cmd == "state":
        cmd_state()
    elif cmd == "spending":
        if "--summary" in args or len(args) == 1:
            cmd_spending_summary()
        elif "--top" in args:
            idx = args.index("--top")
            n = int(args[idx + 1]) if idx + 1 < len(args) else 10
            cmd_spending_top(n)
        elif "--category" in args:
            idx = args.index("--category")
            if idx + 1 < len(args):
                cmd_spending_category(args[idx + 1])
            else:
                print("Usage: eliot-ctx spending --category <category_name>")
                print(f"Categories: {', '.join(CATEGORY_LABELS.keys())}")
        elif "--daily" in args:
            cmd_spending_daily()
        else:
            cmd_spending_summary()
    elif cmd == "balance":
        cmd_balance()
    elif cmd == "brief":
        cmd_brief()
    elif cmd == "digest":
        cmd_digest(stdout_only="--stdout" in args)
    elif cmd == "todo":
        if len(args) < 2 or args[1] == "list":
            cmd_todo_list()
        elif args[1] == "add" and len(args) >= 3:
            desc = " ".join(args[2:]).strip()
            # Extract --from if present
            source = "self"
            if "--from" in args:
                fi = args.index("--from")
                if fi + 1 < len(args):
                    source = args[fi + 1]
                    # Remove --from and its value from description
                    desc = " ".join(a for i, a in enumerate(args[2:], 2)
                                    if i != fi and i != fi + 1).strip()
            cmd_todo_add(desc, source)
        elif args[1] == "done" and len(args) >= 3:
            cmd_todo_done(int(args[2]))
        elif args[1] == "clean":
            cmd_todo_clean()
        else:
            print("Usage: eliot-ctx todo [list|add|done|clean]")
    elif cmd == "forecast":
        cmd_forecast(args[1:])
    elif cmd == "bridge":
        cmd_bridge(args[1:])
    elif cmd == "import":
        path = args[1] if len(args) > 1 else None
        cmd_import(path)
    else:
        print(f"Unknown command: {cmd}")
        print(__doc__)


if __name__ == "__main__":
    main()
