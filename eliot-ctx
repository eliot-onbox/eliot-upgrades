#!/usr/bin/env python3
"""
eliot-ctx — CLI for querying Eliot's context database.

Usage:
  eliot-ctx last [N]              Show last N events (default 10)
  eliot-ctx location              Last known location
  eliot-ctx state                 Full Tudor state (location, battery, focus)
  eliot-ctx spending [--summary]  Spending breakdown
  eliot-ctx spending --top N      Top N expenses
  eliot-ctx spending --category X Show transactions in category
  eliot-ctx spending --daily      Daily spending averages
  eliot-ctx balance               Current balance and burn rate
  eliot-ctx import [csv_path]     Import Revolut CSV
  eliot-ctx brief                 Compact context line for heartbeat
  eliot-ctx digest [--stdout]     Gather today's data, append to daily note
  eliot-ctx todo                  List pending tasks from TASKQUEUE.md
  eliot-ctx todo add "task"       Add task (--from tudor|self)
  eliot-ctx todo done N           Mark task N as done
  eliot-ctx todo clean            Remove completed tasks
  eliot-ctx forecast [--income N] 30-day balance projection
  eliot-ctx bridge [N]            Last N bridge conversations (default all today)
  eliot-ctx bridge --stats        Message counts and frequency
"""

import json
import os
import re
import subprocess
import sys
from datetime import datetime, timedelta

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from db import get_conn, init_db, DB_PATH
from categories import CATEGORY_LABELS

STATE_FILE = "/home/eliot/workspace/data/tudor-state.json"
MEMORY_DIR = os.path.expanduser("~/.openclaw/workspace/memory")
TASKQUEUE_PATH = os.path.expanduser("~/.openclaw/workspace/TASKQUEUE.md")
PROJECTS_DIR = os.path.expanduser("~/projects")
BRIDGE_LOG = os.path.expanduser("~/projects/agent-bridge/conversations.log")


def cmd_last(n: int = 10):
    conn = get_conn()
    rows = conn.execute(
        "SELECT timestamp, event_type, payload, source FROM events ORDER BY id DESC LIMIT ?",
        (n,),
    ).fetchall()
    conn.close()

    if not rows:
        print("No events recorded yet.")
        return

    for r in rows:
        payload = json.loads(r["payload"])
        payload_short = json.dumps(payload) if len(json.dumps(payload)) < 80 else json.dumps(payload)[:77] + "..."
        print(f"  {r['timestamp']}  [{r['event_type']:>10s}]  {r['source']:>7s}  {payload_short}")


def cmd_location():
    if not os.path.exists(STATE_FILE):
        print("No state file yet. Waiting for first iPhone event.")
        return

    with open(STATE_FILE) as f:
        state = json.load(f)

    loc = state.get("location")
    if not loc:
        print("No location data yet.")
        return

    print(f"  Location: {loc['name']}")
    print(f"  Event:    {loc['event']}")
    print(f"  Updated:  {loc['updated_at']}")


def cmd_state():
    if not os.path.exists(STATE_FILE):
        print("No state file yet. Waiting for first iPhone event.")
        return

    with open(STATE_FILE) as f:
        state = json.load(f)

