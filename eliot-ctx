def cmd_spending_top(n: int = 10):
    conn = get_conn()
    rows = conn.execute(
        """SELECT description, amount, currency, completed_date, category
           FROM transactions
           WHERE amount < 0 AND state = 'COMPLETED'
           AND category NOT IN ('savings_transfer', 'currency_exchange')
           ORDER BY amount ASC LIMIT ?""",
        (n,),
    ).fetchall()
    conn.close()

    print(f"\n  Top {n} largest expenses:")
    for r in rows:
        label = CATEGORY_LABELS.get(r["category"], r["category"])
        date = r["completed_date"][:10] if r["completed_date"] else "pending"
        print(f"    {date}  {r['amount']:>10.2f} {r['currency']}  {r['description']:<35s}  [{label}]")


def cmd_spending_category(cat: str):
    conn = get_conn()
    rows = conn.execute(
        """SELECT description, amount, currency, completed_date
           FROM transactions
           WHERE category = ? AND state = 'COMPLETED'
           ORDER BY completed_date DESC""",
        (cat,),
    ).fetchall()
    total = conn.execute(
        "SELECT SUM(amount) FROM transactions WHERE category = ? AND state = 'COMPLETED'",
        (cat,),
    ).fetchone()[0]
    conn.close()

    label = CATEGORY_LABELS.get(cat, cat)
