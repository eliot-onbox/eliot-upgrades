    for r in rows:
        date = r["completed_date"][:10] if r["completed_date"] else "pending"
        print(f"    {date}  {r['amount']:>10.2f} {r['currency']}  {r['description']}")


def cmd_spending_daily():
    conn = get_conn()
    rows = conn.execute(
        """SELECT DATE(completed_date) as day, SUM(amount) as total, COUNT(*) as count
           FROM transactions
           WHERE currency = 'EUR' AND product = 'Current'
           AND amount < 0 AND state = 'COMPLETED'
           AND category NOT IN ('savings_transfer', 'currency_exchange')
           AND completed_date IS NOT NULL
           GROUP BY day ORDER BY day""",
    ).fetchall()
    conn.close()

    if not rows:
        print("No spending data.")
        return

    total_spent = sum(r["total"] for r in rows)
    num_days = len(rows)
    avg = total_spent / num_days if num_days else 0

    print(f"\n  Daily EUR spending ({num_days} days):")
    print(f"  Average: {avg:.2f} EUR/day")
    print()
    for r in rows:
        bar = "#" * min(50, int(abs(r["total"]) / 5))
        print(f"    {r['day']}  {r['total']:>8.2f} EUR  ({r['count']:>2d} txns)  {bar}")


def cmd_balance():
    from spending import spending_summary

    summary = spending_summary("EUR", "Current")
    balance = summary["current_balance"]
    if balance is None:
        print("No balance data.")
        return

    # Calculate daily burn rate from last 14 days
    conn = get_conn()
    rows = conn.execute(
        """SELECT SUM(amount) as total, COUNT(DISTINCT DATE(completed_date)) as days
           FROM transactions
           WHERE currency = 'EUR' AND product = 'Current'
           AND amount < 0 AND state = 'COMPLETED'
           AND category NOT IN ('savings_transfer', 'currency_exchange', 'loan_payment', 'remittance')
           AND completed_date >= date('now', '-14 days')""",
    ).fetchone()
    conn.close()

    daily_burn = abs(rows["total"] / rows["days"]) if rows["days"] and rows["total"] else 0

    print(f"\n  Current balance: {balance:.2f} EUR")
    if daily_burn > 0:
        days_left = balance / daily_burn
        zero_date = datetime.now() + timedelta(days=days_left)
        print(f"  Daily burn rate: {daily_burn:.2f} EUR/day (last 14 days, excl. loans/remittances)")
        print(f"  Days until zero: {days_left:.0f} days ({zero_date.strftime('%B %d')})")
    else:
        print("  Not enough recent data for burn rate.")


def cmd_brief():
    """One compact context block for heartbeat consumption."""
    lines = []

    # Tudor state from webhooks
    if os.path.exists(STATE_FILE):
        with open(STATE_FILE) as f:
            state = json.load(f)

        loc = state.get("location")
        if loc:
            ago = _time_ago(loc["updated_at"])
            lines.append(f"Tudor {loc['event']} {loc['name']} ({ago})")

        bat = state.get("battery")
        if bat:
            charging = ", charging" if bat.get("charging") else ""
            lines.append(f"Battery: {bat['level']}%{charging}")

        focus = state.get("focus")
        if focus and focus.get("active"):
            lines.append(f"Focus: {focus['mode']}")

    # Financial snapshot
    conn = get_conn()
    last_balance = conn.execute(
        """SELECT balance FROM transactions
           WHERE currency = 'EUR' AND product = 'Current'
           AND balance IS NOT NULL AND state = 'COMPLETED'
           ORDER BY completed_date DESC LIMIT 1""",
    ).fetchone()

    if last_balance:
        balance = last_balance["balance"]
        burn_row = conn.execute(
            """SELECT SUM(amount) as total, COUNT(DISTINCT DATE(completed_date)) as days
               FROM transactions
               WHERE currency = 'EUR' AND product = 'Current'
               AND amount < 0 AND state = 'COMPLETED'
               AND category NOT IN ('savings_transfer', 'currency_exchange', 'loan_payment', 'remittance')
               AND completed_date >= date('now', '-14 days')""",
        ).fetchone()

        if burn_row["days"] and burn_row["total"]:
            daily_burn = abs(burn_row["total"] / burn_row["days"])
            days_left = balance / daily_burn if daily_burn > 0 else 999
            zero_date = datetime.now() + timedelta(days=days_left)
            lines.append(f"Balance: EUR{balance:.0f} (~{days_left:.0f}d at EUR{daily_burn:.0f}/day, zero {zero_date.strftime('%b %d')})")
        else:
            lines.append(f"Balance: EUR{balance:.0f}")

    conn.close()

    # Recent events count
    conn = get_conn()
    recent = conn.execute(
        "SELECT COUNT(*) FROM events WHERE created_at >= datetime('now', '-24 hours')"
    ).fetchone()[0]
    conn.close()
    if recent > 0:
        lines.append(f"Events (24h): {recent}")

    if lines:
        print("CONTEXT: " + " | ".join(lines))
    else:
        print("CONTEXT: No data yet. Webhook system running, awaiting first iPhone events.")


def _time_ago(iso_str: str) -> str:
    try:
        dt = datetime.fromisoformat(iso_str)
        delta = datetime.now() - dt
        minutes = int(delta.total_seconds() / 60)
        if minutes < 1:
            return "just now"
        if minutes < 60:
            return f"{minutes}m ago"
        hours = minutes // 60
        if hours < 24:
            return f"{hours}h ago"
        return f"{hours // 24}d ago"
    except (ValueError, TypeError):
        return "unknown"


def cmd_digest(stdout_only: bool = False):
    """Gather today's data from all sources. Append to daily note or print."""
    today = datetime.now().strftime("%Y-%m-%d")
    sections = []

    # 1. Git commits across all projects
    git_lines = []
    if os.path.isdir(PROJECTS_DIR):
        for name in sorted(os.listdir(PROJECTS_DIR)):
            repo = os.path.join(PROJECTS_DIR, name)
            git_dir = os.path.join(repo, ".git")
            if not os.path.exists(git_dir):
                continue
            try:
                result = subprocess.run(
                    ["git", "-C", repo, "log", "--oneline", "--since=midnight", "--format=%h %s"],
                    capture_output=True, text=True, timeout=5,
                )
                if result.stdout.strip():
                    for line in result.stdout.strip().split("\n"):
                        git_lines.append(f"  {name}: {line}")
            except (subprocess.TimeoutExpired, FileNotFoundError):
                pass

    if git_lines:
        sections.append("### Git Activity\n" + "\n".join(git_lines))

    # 2. Files created/modified today in workspace
    file_changes = []
    workspace = os.path.expanduser("~/.openclaw/workspace")
    for dirpath, _dirs, filenames in os.walk(workspace):
        # Skip deep nested dirs
        depth = dirpath.replace(workspace, "").count(os.sep)
        if depth > 2:
            continue
        for f in filenames:
            fp = os.path.join(dirpath, f)
            try:
                mtime = datetime.fromtimestamp(os.path.getmtime(fp))
                if mtime.strftime("%Y-%m-%d") == today:
                    rel = fp.replace(workspace + "/", "")
                    file_changes.append(f"  {rel} (modified {mtime.strftime('%H:%M')})")
            except OSError:
                pass

    if file_changes:
        sections.append("### Workspace Files Modified\n" + "\n".join(file_changes[:20]))

    # 3. Webhook events today
    conn = get_conn()
    event_summary = conn.execute(
        """SELECT event_type, COUNT(*) as c
           FROM events WHERE DATE(created_at) = ?
           GROUP BY event_type ORDER BY c DESC""",
        (today,),
    ).fetchall()
    conn.close()

    if event_summary:
        ev_lines = [f"  {r['event_type']}: {r['c']}" for r in event_summary]
        sections.append("### Webhook Events\n" + "\n".join(ev_lines))

    # 4. Agent bridge conversations today
    bridge_lines = []
    if os.path.exists(BRIDGE_LOG):
        with open(BRIDGE_LOG) as f:
            for line in f:
                if f"[{today}" in line:
                    # Strip to just direction + preview
                    m = re.match(r'\[.*?\] (IN|OUT) \(.*?\): (.+)', line.strip())
                    if m:
                        direction = "Ela->" if m.group(1) == "IN" else "->Ela"
                        msg = m.group(2)[:100]
                        bridge_lines.append(f"  {direction}: {msg}")

    if bridge_lines:
        sections.append("### Agent Bridge\n" + "\n".join(bridge_lines))

    # 5. Financial snapshot
    conn = get_conn()
    last_bal = conn.execute(
        """SELECT balance FROM transactions
           WHERE currency='EUR' AND product='Current' AND balance IS NOT NULL
           AND state='COMPLETED' ORDER BY completed_date DESC LIMIT 1""",
    ).fetchone()
    tx_today = conn.execute(
        "SELECT COUNT(*) FROM transactions WHERE DATE(completed_date) = ?", (today,)
    ).fetchone()[0]
    conn.close()

    if last_bal:
        sections.append(f"### Finance\n  Balance: EUR {last_bal['balance']:.2f}\n  Transactions today: {tx_today}")

    # 6. System services
    svc_lines = []
    try:
        result = subprocess.run(
            ["systemctl", "list-units", "--type=service", "--state=running", "--no-pager", "--plain"],
            capture_output=True, text=True, timeout=5,
        )
        for line in result.stdout.split("\n"):
            if "eliot" in line.lower() or "agent" in line.lower() or "openclaw" in line.lower():
                svc_lines.append(f"  {line.strip().split()[0]}")
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass

    if svc_lines:
        sections.append("### Running Services\n" + "\n".join(svc_lines))

    # Assemble output
    if not sections:
        print("No activity found for today.")
        return

    digest_text = f"\n## Auto-Digest ({datetime.now().strftime('%H:%M')})\n\n" + "\n\n".join(sections) + "\n"

    if stdout_only:
        print(digest_text)
        return

    # Append to daily note
    note_path = os.path.join(MEMORY_DIR, f"{today}.md")
    if os.path.exists(note_path):
        with open(note_path, "a") as f:
            f.write(digest_text)
        print(f"Appended digest to {note_path}")
    else:
        with open(note_path, "w") as f:
            f.write(f"# {today}\n{digest_text}")
        print(f"Created {note_path} with digest")


# --- TASKQUEUE management ---

def _parse_taskqueue():
    """Parse TASKQUEUE.md into a list of (done, text) tuples."""
    tasks = []
    if not os.path.exists(TASKQUEUE_PATH):
        return tasks
    with open(TASKQUEUE_PATH) as f:
        for line in f:
            m = re.match(r'^- \[([ xX])\] (.+)$', line.strip())
            if m:
                done = m.group(1).lower() == 'x'
                tasks.append({"done": done, "text": m.group(2)})
    return tasks


def _write_taskqueue(tasks, header=None):
    """Write tasks back to TASKQUEUE.md, preserving header."""
    if header is None:
        header = (
            "# TASKQUEUE.md -- Deferred Tasks\n"
            "# Tasks queued here when usage is too low to execute.\n"
            "# Heartbeat checks usage + picks these up when limits reset.\n"
            "# Format: - [ ] TASK DESCRIPTION (queued: DATE, from: Tudor/self)\n"
        )
    else:
        # Read existing header lines (comments at the top)
        pass

    # Preserve original header from file
    lines = []
    if os.path.exists(TASKQUEUE_PATH):
        with open(TASKQUEUE_PATH) as f:
            for line in f:
                if line.startswith("#") or line.strip() == "":
                    lines.append(line)
                else:
                    break

    if not lines:
        lines = [
            "# TASKQUEUE.md -- Deferred Tasks\n",
            "# Format: - [ ] TASK (queued: DATE, from: source)\n",
            "\n",
        ]

    with open(TASKQUEUE_PATH, "w") as f:
        f.writelines(lines)
        for t in tasks:
            mark = "x" if t["done"] else " "
            f.write(f"- [{mark}] {t['text']}\n")


def cmd_todo_list():
    tasks = _parse_taskqueue()
    if not tasks:
        print("No tasks in TASKQUEUE.md")
        return

    pending = [t for t in tasks if not t["done"]]
    done = [t for t in tasks if t["done"]]

    if pending:
        print(f"  Pending ({len(pending)}):")
        for i, t in enumerate(tasks):
            if not t["done"]:
                print(f"    {i+1}. [ ] {t['text']}")

    if done:
        print(f"  Done ({len(done)}):")
        for i, t in enumerate(tasks):
            if t["done"]:
                print(f"    {i+1}. [x] {t['text']}")


def cmd_todo_add(description: str, source: str = "self"):
    tasks = _parse_taskqueue()
    today = datetime.now().strftime("%Y-%m-%d")
    entry = f"{description} (queued: {today}, from: {source})"
    tasks.append({"done": False, "text": entry})
    _write_taskqueue(tasks)
    print(f"  Added: {entry}")


def cmd_todo_done(task_num: int):
    tasks = _parse_taskqueue()
    if task_num < 1 or task_num > len(tasks):
        print(f"  Invalid task number {task_num}. Range: 1-{len(tasks)}")
        return

    t = tasks[task_num - 1]
    if t["done"]:
        print(f"  Already done: {t['text']}")
        return

    t["done"] = True
    _write_taskqueue(tasks)
    print(f"  Done: {t['text']}")


def cmd_todo_clean():
    tasks = _parse_taskqueue()
    before = len(tasks)
    tasks = [t for t in tasks if not t["done"]]
    after = len(tasks)
    _write_taskqueue(tasks)
    print(f"  Removed {before - after} completed tasks. {after} remaining.")


